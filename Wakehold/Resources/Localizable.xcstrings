    "Keep the display on" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إبقاء الشاشة مضاءة"
          }
        }
      }
    },
    "Launch at login" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التشغيل عند تسجيل الدخول"
          }
        }
      }
    },
    "Nothing's keeping you awake." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا شيء يُبقيك مستيقظًا."
          }
        }
      }
    },
    "On, the screen stays lit while a session holds. Off, the system stays awake but the display can sleep, for unattended work." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند التشغيل، تبقى الشاشة مضاءة أثناء استمرار الجلسة. عند الإيقاف، يبقى النظام مستيقظًا بينما يمكن للشاشة أن تنام، للعمل دون إشراف."
          }
        }
      }
    },
